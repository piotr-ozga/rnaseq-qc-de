nextflow_process {

    name "Test Process TRIMGALORE"
    script "modules/local/trimgalore/main.nf"
    process "TRIMGALORE"

    tag "modules"
    tag "trimgalore"

    test("[PE] trims paired-end reads and outputs gzipped fastq") {

        when{
            process {
                """
                def data_dir = "\${projectDir}/tests/data/yeast/reads"
                input[0] = [
                    [ id: "WT_REP1", single_end: false ],
                    [
                        file("\${data_dir}/SRR6357070_1.fastq.gz", checkIfExists: true),
                        file("\${data_dir}/SRR6357070_2.fastq.gz", checkIfExists: true)
                    ]
                ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.reads[0][1].size() == 2
            assert process.out.reads[0][1].every { it.endsWith(".fq.gz") }

            // Check if software version is correctly collected
            assert process.out.version[0][1] == 'trim_galore'
            assert process.out.version[0][2] =~ /\d+\.\d+\.\d+/
        }
    }

    test("[SE] trims single-end reads and outputs gzipped fastq") {

        when{
            process {
                """
                def data_dir = "\${projectDir}/tests/data/yeast/reads"
                input[0] = [
                    [ id: "RAP1_UNINDUCED", single_end: true ],
                    file("\${data_dir}/SRR6357073_1.fastq.gz", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.reads[0][1].endsWith(".fq.gz")
            assert process.out.log[0][1].contains("SRR6357073_1.fastq.gz_trimming_report.txt")
        }
    }


}