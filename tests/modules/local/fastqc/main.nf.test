nextflow_process {

    name "Test Process FASTQC"
    script "modules/local/fastqc/main.nf"
    process "FASTQC"

    test("[SE] stub") {
        options "-stub"

        when{
            process {
                """
                input[0] = [ [ id:"test_sample", single_end: true ] , file("test.fastq.gz") ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.html[0][1].toString().endsWith('.html')
            assert process.out.zip[0][1].toString().endsWith('.zip')
        }
    }

    test("[PE] stub") {
        options "-stub"
        when{
            process {
                """
                input[0] = [ [ id:"test_sample", single_end: false ] , [ file("test_1.fastq.gz"), file("test_2.fastq.gz") ] ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.html[0][1].size() == 2
            assert process.out.zip[0][1].size() == 2

            process.out.html[0][1].each { assert it.toString().endsWith('.html') }
            process.out.zip[0][1].each { assert it.toString().endsWith('.zip') }
        }
    }


}