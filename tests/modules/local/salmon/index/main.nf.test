nextflow_process {

    name "Test Process SALMON_INDEX"
    script "modules/local/salmon/index/main.nf"
    process "SALMON_INDEX"

    tag "modules"
    tag "salmon_index"

    test("builds salmon index from genome and transcriptome") {
        when{
            process {
                """
                input[0] = params.genome_fasta
                input[1] = params.transcriptome_fasta
                """
            }
        }

        then {
            assert process.success

            assert process.out.index != null
            
            // Check if software versions are correctly collected
            assert process.out.version[0][1] == 'salmon'
            assert process.out.version[0][2] =~ /\d+\.\d+\.\d+/
        }
    }
}